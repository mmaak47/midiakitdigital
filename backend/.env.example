# Environment variables for Intermidia Mídia Kit Backend
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Server ─────────────────────────────────────────────────────────────────
NODE_ENV=production
# PORT is set automatically by Phusion Passenger — do NOT set it manually on cPanel.
# On a VPS with PM2, set: PORT=3002

# Used to sign admin auth tokens. Keep this stable across restarts.
AUTH_SECRET=replace-with-a-long-random-secret

# ── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
FRONTEND_ORIGINS=https://yourdomain.com

# ── Database (PostgreSQL preferred for new systems) ────────────────────────
# Keep DB_ENGINE=sqlite while legacy modules are still using better-sqlite3.
# Use DB_ENGINE=postgres only after query layer migration is complete.
DB_ENGINE=sqlite
# Example:
# DATABASE_URL=postgresql://midiakit_app:strongpassword@127.0.0.1:5432/midiakit_prod?schema=public

# SQLite compatibility path (legacy runtime)
SQLITE_PATH=./midiakit.db

# ── License ────────────────────────────────────────────────────────────────
# If both are left blank, license check is bypassed (useful for local dev).
LICENSE_URL=
LICENSE_CLIENT=
# Hours to keep operating if the license server is unreachable (default: 24)
LICENSE_GRACE_H=24

# ── SQLite Backup ──────────────────────────────────────────────────────────
SQLITE_BACKUP_ENABLED=true
# SQLITE_BACKUP_INTERVAL_HOURS=6
# SQLITE_BACKUP_RETENTION_DAYS=7

# ── Rate Limiting ──────────────────────────────────────────────────────────
# API_RATE_LIMIT_MAX=100

# ── Entorno Auto-Refresh ───────────────────────────────────────────────────
# ENTORNO_AUTO_REFRESH_ENABLED=false
