# Environment variables for Intermidia Mídia Kit Backend
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Server ─────────────────────────────────────────────────────────────────
NODE_ENV=production
# PORT is set automatically by Phusion Passenger — do NOT set it manually on cPanel.
# On a VPS with PM2, set: PORT=3002

# Used to sign admin auth tokens. Keep this stable across restarts.
AUTH_SECRET=replace-with-a-long-random-secret

# ── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
FRONTEND_ORIGINS=https://yourdomain.com

# ── Database (PostgreSQL preferred for new systems) ────────────────────────
# Keep DB_ENGINE=sqlite while legacy modules are still using better-sqlite3.
# Use DB_ENGINE=postgres only after query layer migration is complete.
DB_ENGINE=sqlite
# Example:
# DATABASE_URL=postgresql://midiakit_app:strongpassword@127.0.0.1:5432/midiakit_prod?schema=public

# SQLite compatibility path (legacy runtime)
SQLITE_PATH=./midiakit.db

# ── License ────────────────────────────────────────────────────────────────
# If both are left blank, license check is bypassed (useful for local dev).
LICENSE_URL=
LICENSE_CLIENT=
# Hours to keep operating if the license server is unreachable (default: 24)
LICENSE_GRACE_H=24

# ── SQLite Backup ──────────────────────────────────────────────────────────
SQLITE_BACKUP_ENABLED=true
# SQLITE_BACKUP_INTERVAL_HOURS=6
# SQLITE_BACKUP_RETENTION_DAYS=7

# ── Rate Limiting ──────────────────────────────────────────────────────────
# API_RATE_LIMIT_MAX=600
# LOGIN_RATE_LIMIT_MAX=15
# PDF_RENDER_RATE_LIMIT_MAX=50
# PDF_MAX_QUEUE=8
# PDF_RENDER_TIMEOUT_MS=180000
# PDF_BROWSER_RECYCLE_EVERY=30
# PDF_FONT_READY_TIMEOUT_MS=4000
# PDF_IMAGE_WAIT_TIMEOUT_MS=7000
# PDF_LAYOUT_SETTLE_MS=120
# MONITOR_RATE_LIMIT_MAX=120

# ── CORS para endpoints de monitores (players de tela) ────────────────────
# Origens permitidas para /api/monitors e /api/loop-audit.
# Se não definido, usa as mesmas origens do FRONTEND_ORIGINS.
# MONITOR_ORIGINS=https://player.yourdomain.com,https://player2.yourdomain.com

# ── Evolution API (WhatsApp) ───────────────────────────────────────────────
# Preferível configurar aqui em vez de pelo painel admin (evita chave em texto no banco).
# Se definidos aqui, sobrescrevem os valores salvos no banco via painel admin.
# EVOLUTION_API_URL=https://sua-instancia.evolution.com
# EVOLUTION_INSTANCE=nome-da-instancia
# EVOLUTION_API_KEY=sua-chave-secreta
# EVOLUTION_DEST_NUMBER=5511999999999
# EVOLUTION_FINANCEIRO_NUMBER=5511888888888

# ── Entorno Auto-Refresh ───────────────────────────────────────────────────
# ENTORNO_AUTO_REFRESH_ENABLED=false
